{
  "name": "uepm-monorepo",
  "version": "1.0.5",
  "private": true,
  "description": "Unreal Engine Package Manager - Monorepo",
  "workspaces": [
    "packages/*",
    "samples/plugins/*",
    "samples/tests"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "unreal",
    "unreal-engine",
    "plugin",
    "package-manager",
    "monorepo"
  ],
  "author": "",
  "license": "MIT"
}
