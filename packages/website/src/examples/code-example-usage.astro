---
// Example usage of the CodeExample component
import CodeExample from '../components/CodeExample.astro';

const quickStartSteps = [
  {
    label: 'Initialize UEPM',
    code: 'npx @uepm/init',
    language: 'bash' as const,
    explanation: 'This command initializes UEPM in your Unreal Engine project directory.'
  },
  {
    label: 'Install a Plugin',
    code: 'uepm install example-plugin',
    language: 'bash' as const,
    explanation: 'Install any plugin from the UEPM registry or GitHub.'
  },
  {
    label: 'Configure Dependencies',
    code: `{
  "name": "MyProject",
  "version": "1.0.0",
  "dependencies": {
    "example-plugin": "^2.1.0",
    "ui-toolkit": "^1.5.0"
  }
}`,
    language: 'json' as const,
    explanation: 'Your package.json file will track all plugin dependencies.'
  }
];

const advancedSteps = [
  {
    label: 'Programmatic Usage',
    code: `import { UEPMManager } from "@uepm/core";

const manager = new UEPMManager();
await manager.install("example-plugin");
await manager.validate();`,
    language: 'typescript' as const,
    explanation: 'Use UEPM programmatically in your build scripts or tools.'
  }
];
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UEPM Code Examples</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; padding: 2rem; background: #f9fafb; }
    .container { max-width: 1200px; margin: 0 auto; }
    h1 { color: #1f2937; margin-bottom: 2rem; }
  </style>
</head>
<body>
  <div class="container">
    <h1>UEPM Usage Examples</h1>
    
    <CodeExample
      title="Quick Start Guide"
      description="Get started with UEPM in just a few simple steps."
      steps={quickStartSteps}
    />
    
    <CodeExample
      title="Advanced Usage"
      description="Integrate UEPM into your development workflow."
      steps={advancedSteps}
    />
  </div>
</body>
</html>