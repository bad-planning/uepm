---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import CodeExample from '../components/CodeExample.astro';
import GetStarted from '../components/GetStarted.astro';
import Footer from '../components/Footer.astro';
import { homePageContent } from '../config/content.ts';
import { getSiteConfig } from '../config/site.ts';

const siteConfig = getSiteConfig();
const { hero, features, codeExamples, getStarted } = homePageContent;
---

<Layout title={siteConfig.title}>
  <!-- Hero Section -->
  <Hero 
    title={hero.title}
    subtitle={hero.subtitle}
    primaryCTA={hero.primaryCTA}
    secondaryCTA={hero.secondaryCTA}
    codePreview={hero.codePreview}
  />
  
  <!-- Features Section -->
  <Features 
    title="Why Choose UEPM?"
    subtitle="Powerful features that transform your Unreal Engine plugin development workflow"
    features={features}
  />
  
  <!-- Code Examples Section -->
  <section class="py-16 bg-gray-50" id="examples">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl mb-4">
          See UEPM in Action
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Experience the power of NPM-style workflows in Unreal Engine development. 
          From initialization to plugin management, UEPM makes it simple.
        </p>
      </div>
      
      <!-- Quick Start Example -->
      <div class="mb-16">
        <CodeExample 
          title={codeExamples.quickStart.title}
          description={codeExamples.quickStart.description}
          steps={codeExamples.quickStart.steps}
        />
      </div>
      
      <!-- Plugin Installation Example -->
      <div class="mb-16">
        <CodeExample 
          title={codeExamples.pluginInstall.title}
          description={codeExamples.pluginInstall.description}
          steps={codeExamples.pluginInstall.steps}
        />
      </div>
      
      <!-- Package Configuration Example -->
      <div class="mb-8">
        <CodeExample 
          title={codeExamples.packageJson.title}
          description={codeExamples.packageJson.description}
          steps={codeExamples.packageJson.steps}
        />
      </div>
    </div>
  </section>
  
  <!-- Compatibility and Requirements Section -->
  <section class="py-16 bg-white" id="compatibility">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl mb-4">
          System Requirements
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          UEPM is designed to work seamlessly with modern Unreal Engine versions and development environments.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Unreal Engine Compatibility -->
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-lg p-6 border border-blue-100">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="ml-3 text-lg font-semibold text-gray-900">Unreal Engine</h3>
          </div>
          <ul class="space-y-2 text-sm text-gray-700">
            <li class="flex items-center">
              <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              UE 5.3+ (Recommended)
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              UE 5.1+ (Supported)
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-yellow-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
              UE 4.27+ (Limited support)
            </li>
          </ul>
        </div>
        
        <!-- Platform Support -->
        <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-lg p-6 border border-green-100">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9"></path>
              </svg>
            </div>
            <h3 class="ml-3 text-lg font-semibold text-gray-900">Platforms</h3>
          </div>
          <ul class="space-y-2 text-sm text-gray-700">
            <li class="flex items-center">
              <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Windows 10/11
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              macOS 12+ (Intel & Apple Silicon)
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Linux (Ubuntu 20.04+)
            </li>
          </ul>
        </div>
        
        <!-- Development Tools -->
        <div class="bg-gradient-to-br from-purple-50 to-violet-50 rounded-lg p-6 border border-purple-100">
          <div class="flex items-center mb-4">
            <div class="flex-shrink-0">
              <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 class="ml-3 text-lg font-semibold text-gray-900">Prerequisites</h3>
          </div>
          <ul class="space-y-2 text-sm text-gray-700">
            <li class="flex items-center">
              <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Node.js 18+ & NPM 9+
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Git (for version control)
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 text-blue-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Visual Studio (Windows) or Xcode (macOS)
            </li>
          </ul>
        </div>
      </div>
      
      <!-- Installation Note -->
      <div class="mt-12 bg-blue-50 border border-blue-200 rounded-lg p-6">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <svg class="w-6 h-6 text-blue-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-lg font-semibold text-blue-900 mb-2">Quick Installation Check</h3>
            <p class="text-blue-800 mb-3">
              Verify your system meets the requirements by running these commands in your terminal:
            </p>
            <div class="bg-blue-900 text-blue-100 p-3 rounded font-mono text-sm overflow-x-auto">
              <div>node --version  # Should show v18.0.0 or higher</div>
              <div>npm --version   # Should show 9.0.0 or higher</div>
              <div>git --version   # Should show any recent version</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Get Started Section -->
  <GetStarted 
    title={getStarted.title}
    subtitle={getStarted.subtitle}
    quickStartCommand={getStarted.quickStartCommand}
    showCodeExample={true}
  />
  
  <!-- Footer -->
  <Footer />
</Layout>
