---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="UEPM - NPM for Unreal Engine Plugins">
  <Hero 
    title="NPM for Unreal Engine Plugins"
    subtitle="Bringing familiar package management workflows to Unreal Engine development. Install, manage, and distribute plugins with the simplicity of NPM."
    primaryCTA={{
      text: "Get Started",
      href: "#get-started"
    }}
    secondaryCTA={{
      text: "View Documentation", 
      href: "https://github.com/uepm/uepm#readme"
    }}
    codePreview="npx @uepm/init"
  />
</Layout>
