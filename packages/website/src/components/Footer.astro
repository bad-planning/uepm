---
import { getSiteConfig, footerLinks } from '../config';

export interface Props {
  showNewsletter?: boolean;
}

const { showNewsletter = false } = Astro.props;
const siteConfig = getSiteConfig();

const currentYear = new Date().getFullYear();
---

<footer 
  class="bg-gray-50 border-t border-gray-200"
  role="contentinfo"
  aria-labelledby="footer-heading"
>
  <div class="container py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand section -->
      <div class="lg:col-span-1">
        <div class="flex items-center space-x-2 mb-4">
          <svg 
            class="w-8 h-8 text-blue-600" 
            fill="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
          <span class="text-xl font-bold text-gradient-primary">UEPM</span>
        </div>
        
        <p class="text-gray-600 mb-6 leading-relaxed">
          NPM for Unreal Engine Plugins. Bringing familiar package management workflows to Unreal Engine development.
        </p>
        
        <!-- Social links -->
        <div class="flex space-x-4">
          <a 
            href={siteConfig.social.github}
            class="text-gray-400 hover:text-gray-600 transition-colors duration-200"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="UEPM on GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          
          <a 
            href={siteConfig.social.npm}
            class="text-gray-400 hover:text-gray-600 transition-colors duration-200"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="UEPM on NPM"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0H1.763zM5.13 5.323l13.837.019-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Product links -->
      <div>
        <h3 
          class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4"
          id="footer-product-heading"
        >
          Product
        </h3>
        <ul class="space-y-3" role="list" aria-labelledby="footer-product-heading">
          {footerLinks.product.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer-link"
                target={link.external ? '_blank' : '_self'}
                rel={link.external ? 'noopener noreferrer' : ''}
              >
                {link.text}
                {link.external && (
                  <svg 
                    class="w-3 h-3 ml-1 inline-block" 
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community links -->
      <div>
        <h3 
          class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4"
          id="footer-community-heading"
        >
          Community
        </h3>
        <ul class="space-y-3" role="list" aria-labelledby="footer-community-heading">
          {footerLinks.community.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer-link"
                target={link.external ? '_blank' : '_self'}
                rel={link.external ? 'noopener noreferrer' : ''}
              >
                {link.text}
                {link.external && (
                  <svg 
                    class="w-3 h-3 ml-1 inline-block" 
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources links -->
      <div>
        <h3 
          class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4"
          id="footer-resources-heading"
        >
          Resources
        </h3>
        <ul class="space-y-3" role="list" aria-labelledby="footer-resources-heading">
          {footerLinks.resources.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer-link"
                target={link.external ? '_blank' : '_self'}
                rel={link.external ? 'noopener noreferrer' : ''}
              >
                {link.text}
                {link.external && (
                  <svg 
                    class="w-3 h-3 ml-1 inline-block" 
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom section -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <!-- Copyright -->
        <div class="flex items-center space-x-4 mb-4 md:mb-0">
          <p class="text-sm text-gray-500">
            © {currentYear} UEPM. Open source project.
          </p>
          <span class="hidden md:block text-gray-300">•</span>
          <p class="text-sm text-gray-500">
            Built with ❤️ for the Unreal Engine community
          </p>
        </div>

        <!-- Quick actions -->
        <div class="flex items-center space-x-4">
          <a 
            href="#get-started"
            class="btn btn-primary btn-sm px-4 py-2 cta-prominent"
            aria-label="Jump to getting started section"
          >
            Get Started
          </a>
          
          <a 
            href={siteConfig.social.github}
            class="btn btn-ghost btn-sm px-4 py-2"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Star UEPM on GitHub"
          >
            <svg 
              class="w-4 h-4 mr-1" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
            Star
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Footer link styles */
  .footer-link {
    @apply text-gray-600 hover:text-gray-900 transition-colors duration-200 text-sm flex items-center;
  }
  
  .footer-link:focus-visible {
    @apply outline-2 outline-offset-2 outline-blue-600 rounded-sm;
  }
  
  /* Prominent CTA styling in footer */
  .cta-prominent {
    @apply relative;
  }
  
  .cta-prominent::before {
    content: '';
    @apply absolute inset-0 rounded-lg;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(99, 102, 241, 0.1));
    z-index: -1;
    transition: opacity 0.2s ease-in-out;
    opacity: 0;
  }
  
  .cta-prominent:hover::before {
    opacity: 1;
  }
  
  /* Enhanced hover effects */
  .footer-link:hover {
    transform: translateX(2px);
  }
  
  /* Social link hover effects */
  footer a[aria-label*="GitHub"]:hover,
  footer a[aria-label*="NPM"]:hover {
    transform: translateY(-1px);
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    .grid {
      gap: 2rem;
    }
    
    .footer-link {
      @apply text-base;
    }
  }
  
  /* Focus improvements for accessibility */
  footer a:focus-visible {
    @apply outline-2 outline-offset-2 outline-blue-600 rounded-sm;
  }
  
  /* Smooth transitions */
  footer a {
    @apply transition-all duration-200;
  }
</style>