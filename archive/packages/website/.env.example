# UEPM Website Environment Configuration
# Copy this file to .env and update the values for your deployment

# Site Configuration
PUBLIC_SITE_URL=https://uepm.dev

# Analytics Configuration
# Set to 'vercel', 'plausible', or 'none'
PUBLIC_ANALYTICS_PROVIDER=none
PUBLIC_ANALYTICS_ID=

# For Plausible Analytics, you may also need:
# PUBLIC_PLAUSIBLE_DOMAIN=uepm.dev

# Development Configuration
# These are automatically set by Astro in development
# DEV=true
# PROD=false

# Build Configuration
# NODE_ENV=production