---
import { getSiteConfig, navigationLinks } from '../config';

export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const siteConfig = getSiteConfig();
---

<header 
  class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200/50"
  role="banner"
>
  <nav 
    class="container mx-auto px-4 sm:px-6 lg:px-8"
    aria-label="Main navigation"
  >
    <div class="flex items-center justify-between h-16">
      <!-- Logo/Brand -->
      <div class="flex items-center">
        <a 
          href="/"
          class="flex items-center space-x-2 text-xl font-bold text-gradient-primary hover:opacity-80 transition-opacity duration-200"
          aria-label="UEPM - NPM for Unreal Engine Plugins"
        >
          <svg 
            class="w-8 h-8 text-blue-600" 
            fill="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
          <span>UEPM</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {navigationLinks.map((link) => (
          <>
            <a
              href={link.href}
              class={`nav-link ${currentPath === link.href ? 'nav-link-active' : ''}`}
              target={link.internal ? '_self' : '_blank'}
              rel={link.internal ? '' : 'noopener noreferrer'}
              aria-describedby={link.description ? `nav-${link.text.toLowerCase()}-desc` : undefined}
            >
              {link.text}
              {!link.internal && (
                <svg 
                  class="w-3 h-3 ml-1 inline-block" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              )}
            </a>
            {link.description && (
              <span id={`nav-${link.text.toLowerCase()}-desc`} class="sr-only">
                {link.description}
              </span>
            )}
          </>
        ))}
      </div>

      <!-- CTA Button -->
      <div class="hidden md:flex items-center">
        <a 
          href="#get-started"
          class="btn btn-primary btn-md px-6 py-2 shadow-md hover:shadow-lg transform hover:scale-105 transition-all duration-200"
          aria-describedby="nav-cta-description"
        >
          Get Started
        </a>
        <span id="nav-cta-description" class="sr-only">
          Jump to getting started section
        </span>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          id="mobile-menu-button"
          class="btn btn-ghost btn-sm p-2"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
        >
          <svg 
            id="menu-icon" 
            class="w-6 h-6" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg 
            id="close-icon" 
            class="w-6 h-6 hidden" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation Menu -->
    <div 
      id="mobile-menu"
      class="md:hidden hidden bg-white border-t border-gray-200 py-4"
      role="menu"
    >
      <div class="flex flex-col space-y-4">
        {navigationLinks.map((link) => (
          <a
            href={link.href}
            class={`mobile-nav-link ${currentPath === link.href ? 'mobile-nav-link-active' : ''}`}
            target={link.internal ? '_self' : '_blank'}
            rel={link.internal ? '' : 'noopener noreferrer'}
            role="menuitem"
          >
            <span class="flex items-center justify-between">
              <span class="flex items-center">
                {link.text}
                {!link.internal && (
                  <svg 
                    class="w-3 h-3 ml-1" 
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                )}
              </span>
            </span>
            {link.description && (
              <span class="text-sm text-gray-500 mt-1">{link.description}</span>
            )}
          </a>
        ))}
        
        <!-- Mobile CTA -->
        <div class="pt-4 border-t border-gray-200">
          <a 
            href="#get-started"
            class="btn btn-primary btn-md w-full justify-center"
          >
            Get Started
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle functionality
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    
    if (mobileMenuButton && mobileMenu && menuIcon && closeIcon) {
      mobileMenuButton.addEventListener('click', () => {
        const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
        
        // Toggle menu visibility
        mobileMenu.classList.toggle('hidden');
        
        // Toggle icons
        menuIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
        
        // Update aria-expanded
        mobileMenuButton.setAttribute('aria-expanded', (!isExpanded).toString());
        
        // Focus management
        if (!isExpanded) {
          // Menu is opening - focus first link
          const firstLink = mobileMenu.querySelector('a');
          if (firstLink) {
            firstLink.focus();
          }
        }
      });
      
      // Close mobile menu when clicking outside
      document.addEventListener('click', (event) => {
        const target = event.target as Element;
        if (!mobileMenuButton.contains(target) && !mobileMenu.contains(target)) {
          mobileMenu.classList.add('hidden');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          mobileMenuButton.setAttribute('aria-expanded', 'false');
        }
      });
      
      // Close mobile menu on escape key
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
          mobileMenu.classList.add('hidden');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          mobileMenuButton.setAttribute('aria-expanded', 'false');
          mobileMenuButton.focus();
        }
      });
    }
  });
</script>

<style>
  /* Navigation link styles */
  .nav-link {
    @apply text-gray-600 hover:text-gray-900 font-medium transition-colors duration-200 flex items-center;
  }
  
  .nav-link-active {
    @apply text-blue-600;
  }
  
  .nav-link:focus-visible {
    @apply outline-2 outline-offset-2 outline-blue-600 rounded-sm;
  }
  
  /* Mobile navigation styles */
  .mobile-nav-link {
    @apply block px-4 py-3 text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-lg transition-colors duration-200;
  }
  
  .mobile-nav-link-active {
    @apply text-blue-600 bg-blue-50;
  }
  
  /* Header backdrop blur effect */
  @supports (backdrop-filter: blur(12px)) {
    header {
      backdrop-filter: blur(12px);
    }
  }
  
  /* Ensure header doesn't interfere with page content */
  :global(body) {
    padding-top: 4rem; /* Height of fixed header */
  }
  
  /* Smooth transitions for mobile menu */
  #mobile-menu {
    transition: all 0.2s ease-in-out;
  }
  
  /* Focus styles for better accessibility */
  .nav-link:focus,
  .mobile-nav-link:focus {
    @apply outline-none ring-2 ring-blue-500 ring-offset-2;
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    :global(body) {
      padding-top: 4rem;
    }
  }
</style>