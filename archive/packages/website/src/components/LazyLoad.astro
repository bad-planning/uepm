---
export interface Props {
  threshold?: number;
  rootMargin?: string;
  class?: string;
  fallback?: string;
}

const { 
  threshold = 0.1, 
  rootMargin = '50px',
  class: className = '',
  fallback = ''
} = Astro.props;

const uniqueId = `lazy-${Math.random().toString(36).substr(2, 9)}`;
---

<div 
  id={uniqueId}
  class={`lazy-load ${className}`}
  data-threshold={threshold}
  data-root-margin={rootMargin}
>
  {fallback && (
    <div class="lazy-fallback">
      <Fragment set:html={fallback} />
    </div>
  )}
  <div class="lazy-content" style="display: none;">
    <slot />
  </div>
</div>

<style>
  .lazy-load {
    min-height: 100px; /* Prevent layout shift */
  }
  
  .lazy-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100px;
    background: #f3f4f6;
    border-radius: 0.5rem;
    color: #6b7280;
  }
  
  .lazy-content.loaded {
    display: block !important;
    animation: fadeIn 0.3s ease-in-out;
  }
  
  .lazy-fallback.hidden {
    display: none;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // Intersection Observer for lazy loading
  function initLazyLoading() {
    const lazyElements = document.querySelectorAll('.lazy-load');
    
    if (!lazyElements.length) return;
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const element = entry.target;
          const content = element.querySelector('.lazy-content');
          const fallback = element.querySelector('.lazy-fallback');
          
          if (content) {
            content.style.display = 'block';
            content.classList.add('loaded');
          }
          
          if (fallback) {
            fallback.classList.add('hidden');
          }
          
          observer.unobserve(element);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '50px'
    });
    
    lazyElements.forEach((element) => {
      const threshold = parseFloat(element.dataset.threshold || '0.1');
      const rootMargin = element.dataset.rootMargin || '50px';
      
      // Create a new observer with custom settings if needed
      if (threshold !== 0.1 || rootMargin !== '50px') {
        const customObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const element = entry.target;
              const content = element.querySelector('.lazy-content');
              const fallback = element.querySelector('.lazy-fallback');
              
              if (content) {
                content.style.display = 'block';
                content.classList.add('loaded');
              }
              
              if (fallback) {
                fallback.classList.add('hidden');
              }
              
              customObserver.unobserve(element);
            }
          });
        }, { threshold, rootMargin });
        
        customObserver.observe(element);
      } else {
        observer.observe(element);
      }
    });
  }
  
  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLazyLoading);
  } else {
    initLazyLoading();
  }
</script>