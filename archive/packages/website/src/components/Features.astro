---
import { homePageContent, type Feature } from '../config/content.ts';

export interface Props {
  title?: string;
  subtitle?: string;
  features?: Feature[];
}

const { 
  title = "Why Choose UEPM?",
  subtitle = "Powerful features that transform your Unreal Engine plugin development workflow",
  features = homePageContent.features
} = Astro.props;
---

<section 
  class="features-section section bg-gray-50"
  aria-labelledby="features-title"
>
  <div class="container">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 
        id="features-title"
        class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-6"
      >
        {title}
      </h2>
      <p class="text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        {subtitle}
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
      {features.map((feature, index) => (
        <div 
          class="feature-card group"
          style={`animation-delay: ${index * 0.1}s;`}
        >
          <a 
            href={feature.learnMoreHref || '#'}
            target={feature.learnMoreHref ? "_blank" : "_self"}
            rel={feature.learnMoreHref ? "noopener noreferrer" : ""}
            class="block h-full p-8 bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:border-gray-300 transition-all duration-300 transform hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            aria-describedby={`feature-${index}-description`}
          >
            <!-- Icon -->
            <div class="flex items-center justify-center w-16 h-16 bg-blue-100 rounded-xl mb-6 group-hover:bg-blue-200 transition-colors duration-300">
              {feature.icon === 'Zap' && (
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              )}
              {feature.icon === 'Package' && (
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                </svg>
              )}
              {feature.icon === 'Shield' && (
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              )}
              {feature.icon === 'GitBranch' && (
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              )}
              {feature.icon === 'Wrench' && (
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              )}
              {feature.icon === 'Users' && (
                <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                </svg>
              )}
            </div>

            <!-- Content -->
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors duration-300">
                {feature.title}
              </h3>
              <p 
                id={`feature-${index}-description`}
                class="text-gray-600 leading-relaxed mb-4"
              >
                {feature.description}
              </p>
              

            </div>

            <!-- External link indicator -->
            <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-100">
              <span class="text-sm text-gray-500 group-hover:text-blue-600 transition-colors duration-300">
                Learn more
              </span>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600 group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </div>
          </a>
        </div>
      ))}
    </div>

    <!-- Additional info section -->
    <div class="mt-16 text-center">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 max-w-4xl mx-auto">
        <h3 class="text-2xl font-semibold text-gray-900 mb-4">
          Compatible with Unreal Engine 4.27+ and 5.x
        </h3>
        <p class="text-gray-600 leading-relaxed mb-6">
          UEPM works seamlessly with all modern versions of Unreal Engine. Whether you're working on UE4 projects or the latest UE5 features, UEPM adapts to your development environment.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <span class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-full">
            Unreal Engine 4.27+
          </span>
          <span class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-full">
            Unreal Engine 5.x
          </span>
          <span class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-full">
            Windows & macOS
          </span>
          <span class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-full">
            Linux Support
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-card {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Enhanced hover effects */
  .feature-card:hover {
    transform: translateY(-4px);
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    .features-section .grid {
      gap: 1.5rem;
    }
    
    .feature-card a {
      padding: 1.5rem;
    }
  }
  
  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .feature-card {
      animation: none;
      opacity: 1;
    }
    
    .feature-card:hover {
      transform: none;
    }
    
    .feature-card svg {
      transition: none;
    }
  }
  
  /* Focus improvements */
  .feature-card a:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }
</style>