---
import { getSiteConfig, homePageContent } from '../config';

export interface Props {
  title?: string;
  subtitle?: string;
  quickStartCommand?: string;
  showCodeExample?: boolean;
}

const siteConfig = getSiteConfig();
const content = homePageContent.getStarted;

const { 
  title = content.title,
  subtitle = content.subtitle,
  quickStartCommand = content.quickStartCommand,
  showCodeExample = true
} = Astro.props;
---

<section 
  id="get-started"
  class="section bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 relative overflow-hidden"
  aria-labelledby="get-started-title"
>
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-gradient-to-r from-blue-600/5 via-indigo-600/5 to-purple-600/5"></div>
  <div class="absolute top-0 left-0 w-full h-full">
    <div class="absolute top-1/4 right-1/4 w-64 h-64 bg-blue-400/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-1/4 w-64 h-64 bg-indigo-400/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Section header -->
      <h2 
        id="get-started-title"
        class="text-3xl sm:text-4xl md:text-5xl font-bold text-gradient-primary mb-6"
      >
        {title}
      </h2>
      
      <p class="text-lg sm:text-xl text-gray-600 mb-12 max-w-3xl mx-auto leading-relaxed">
        {subtitle}
      </p>

      {showCodeExample && (
        <!-- Quick start command -->
        <div class="max-w-2xl mx-auto mb-12">
          <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
            <!-- Command header -->
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                <svg 
                  class="w-5 h-5 mr-2 text-green-600" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3"/>
                </svg>
                Quick Start Command
              </h3>
            </div>
            
            <!-- Command content -->
            <div class="p-6">
              <div class="bg-gray-900 rounded-lg p-4 mb-4">
                <div class="flex items-center justify-between">
                  <div class="flex items-center">
                    <span class="text-green-400 font-mono text-sm mr-2">$</span>
                    <code 
                      id="quick-start-command"
                      class="text-gray-100 font-mono text-sm sm:text-base select-all"
                      aria-label="UEPM quick start command"
                    >
                      {quickStartCommand}
                    </code>
                  </div>
                  <button 
                    id="copy-quick-start"
                    class="btn btn-ghost btn-sm text-gray-400 hover:text-white ml-4 flex-shrink-0"
                    aria-label="Copy quick start command to clipboard"
                    data-copy-text={quickStartCommand}
                  >
                    <svg 
                      id="copy-icon-qs" 
                      class="w-4 h-4" 
                      fill="none" 
                      stroke="currentColor" 
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                    </svg>
                    <svg 
                      id="check-icon-qs" 
                      class="w-4 h-4 hidden" 
                      fill="none" 
                      stroke="currentColor" 
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                  </button>
                </div>
              </div>
              
              <p class="text-sm text-gray-600 text-left">
                This command will initialize UEPM in your Unreal Engine project directory and guide you through the setup process.
              </p>
            </div>
          </div>
        </div>
      )}

      <!-- Primary CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
        <a 
          href={siteConfig.documentation.url}
          class="btn btn-primary btn-lg px-8 py-4 text-lg font-semibold shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-200 cta-prominent"
          target="_blank"
          rel="noopener noreferrer"
          aria-describedby="primary-docs-cta-description"
        >
          <svg 
            class="w-5 h-5 mr-2" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C20.832 18.477 19.246 18 17.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
          {siteConfig.documentation.text}
        </a>
        <span id="primary-docs-cta-description" class="sr-only">
          Read the complete documentation and setup guide for UEPM
        </span>
        
        <a 
          href={siteConfig.github.url}
          class="btn btn-secondary btn-lg px-8 py-4 text-lg font-semibold shadow-md hover:shadow-lg transform hover:scale-105 transition-all duration-200 cta-prominent"
          target="_blank"
          rel="noopener noreferrer"
          aria-describedby="github-cta-description"
        >
          <svg 
            class="w-5 h-5 mr-2" 
            fill="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.30.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          {siteConfig.github.text}
        </a>
        <span id="github-cta-description" class="sr-only">
          View the source code, report issues, and contribute to UEPM on GitHub
        </span>
      </div>

      <!-- Secondary links -->
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center text-sm">
        <a 
          href={siteConfig.externalLinks.examples}
          class="text-gray-600 hover:text-blue-600 font-medium transition-colors duration-200 flex items-center"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg 
            class="w-4 h-4 mr-2" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
          Browse Examples
          <svg 
            class="w-3 h-3 ml-1" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
        
        <span class="hidden sm:block text-gray-300">•</span>
        
        <a 
          href={siteConfig.npm.url}
          class="text-gray-600 hover:text-blue-600 font-medium transition-colors duration-200 flex items-center"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg 
            class="w-4 h-4 mr-2" 
            fill="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0H1.763zM5.13 5.323l13.837.019-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z"/>
          </svg>
          View on NPM
          <svg 
            class="w-3 h-3 ml-1" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
        
        <span class="hidden sm:block text-gray-300">•</span>
        
        <span class="text-gray-500 flex items-center">
          <svg 
            class="w-4 h-4 mr-2" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Free & Open Source
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  // Copy to clipboard functionality for quick start command
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.getElementById('copy-quick-start');
    const copyIcon = document.getElementById('copy-icon-qs');
    const checkIcon = document.getElementById('check-icon-qs');
    
    if (copyButton && copyIcon && checkIcon) {
      copyButton.addEventListener('click', async () => {
        const textToCopy = copyButton.getAttribute('data-copy-text');
        if (!textToCopy) return;
        
        try {
          await navigator.clipboard.writeText(textToCopy);
          
          // Show success state
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          copyButton.setAttribute('aria-label', 'Command copied to clipboard');
          
          // Reset after 2 seconds
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
            copyButton.setAttribute('aria-label', 'Copy quick start command to clipboard');
          }, 2000);
          
        } catch (err) {
          console.error('Failed to copy text: ', err);
          
          // Fallback: select the text
          const commandElement = document.getElementById('quick-start-command');
          if (commandElement) {
            const range = document.createRange();
            range.selectNodeContents(commandElement);
            const selection = window.getSelection();
            if (selection) {
              selection.removeAllRanges();
              selection.addRange(range);
            }
          }
          
          // Show success state even for fallback
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          copyButton.setAttribute('aria-label', 'Command selected for copying');
          
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
            copyButton.setAttribute('aria-label', 'Copy quick start command to clipboard');
          }, 2000);
        }
      });
    }
  });
</script>

<style>
  /* Prominent CTA styling */
  .cta-prominent {
    @apply relative;
    min-width: 200px;
  }
  
  .cta-prominent::before {
    content: '';
    @apply absolute inset-0 rounded-lg;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(99, 102, 241, 0.1));
    z-index: -1;
    transition: opacity 0.2s ease-in-out;
    opacity: 0;
  }
  
  .cta-prominent:hover::before {
    opacity: 1;
  }
  
  /* Enhanced button animations */
  .btn:hover {
    transform: translateY(-2px);
  }
  
  .btn:active {
    transform: translateY(0);
  }
  
  /* Code selection styling */
  .select-all {
    user-select: all;
  }
  
  /* Focus improvements */
  .btn:focus-visible {
    @apply outline-2 outline-offset-2 outline-blue-600;
  }
  
  /* Responsive adjustments */
  @media (max-width: 640px) {
    .cta-prominent {
      min-width: auto;
      width: 100%;
    }
  }
  
  /* Animation for section entrance */
  .section {
    animation: fadeInUp 0.6s ease-out;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>